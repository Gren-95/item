{
  "name": "item",
  "version": "1.0.0",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run scripts/watch.ts",
    "dev:full": "bun run build:css && bun run dev",
    "build:css": "bunx tailwindcss -i ./src/styles/input.css -o ./public/css/style.css --minify",
    "build:css:watch": "bunx tailwindcss -i ./src/styles/input.css -o ./public/css/style.css --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "bunx playwright test",
    "test:ui": "bunx playwright test --ui",
    "test:headed": "bunx playwright test --headed",
    "test:debug": "bunx playwright test --debug",
    "test:report": "bunx playwright show-report",
    "certs": "bun run scripts/generate-certs.ts",
    "reset-db": "bun run scripts/reset-db.ts",
    "export-db": "bun run scripts/export-db.ts",
    "import-db": "bun run scripts/import-db.ts",
    "import-mock-data": "bun run scripts/import-mock-data.ts",
    "migrate": "bun run src/migrations/migrate.ts",
    "migrate:force": "bun run src/migrations/migrate.ts --force",
    "migrate:reset": "bun run src/migrations/migrate.ts --reset"
  },
  "dependencies": {
    "mysql2": "^3.11.0",
    "nodemailer": "^7.0.13",
    "qr-scanner": "^1.4.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/bun": "latest",
    "@types/nodemailer": "^6.4.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.1"
  }
}
