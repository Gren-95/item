{
  "name": "item",
  "version": "1.0.0",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run --watch src/server.ts",
    "build:css": "bunx tailwindcss -i ./src/styles/input.css -o ./public/css/style.css --minify",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "certs": "bun run scripts/generate-certs.ts",
    "reset-db": "bun run scripts/reset-db.ts",
    "export-db": "bun run scripts/export-db.ts",
    "import-db": "bun run scripts/import-db.ts",
    "migrate": "bun run src/migrations/migrate.ts",
    "migrate:force": "bun run src/migrations/migrate.ts --force",
    "migrate:reset": "bun run src/migrations/migrate.ts --reset"
  },
  "dependencies": {
    "mysql2": "^3.11.0",
    "qr-scanner": "^1.4.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.1"
  }
}
