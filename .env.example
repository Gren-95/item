# Application
NODE_ENV=development
APP_PORT=4200
API_PORT=3000

# MySQL Database
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=it
MYSQL_USER=item
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=password

# phpMyAdmin
PMA_PORT=8080

# printing service
BARTENDER_HOST=http://localhost/

HTTPS_CERT_FILE=/app/certs/ssl.pem
HTTPS_KEY_FILE=/app/certs/ssl-key.pem
HTTPS_PORT=443

# auth endpoints
AUTH_ENDPOINT=http://rakintra/lswkpi/ajax/t6nu/verifyLogin.php
CHANGE_PASSWORD_ENDPOINT=http://rakintra/lswkpi/ajax/t6nu/changePass.php

# Admin credentials for initial setup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Dell API credentials (replace with actual credentials)
DELL_CLIENT_ID=1234567890
DELL_CLIENT_SECRET=12345678901234567890

# SMTP Configuration for Email Notifications
# Leave SMTP_HOST empty to disable email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=item-noreply@example.com

# Base URL for email links (used in approval notification emails)
BASE_URL=http://localhost:3000

# Approval notification settings
# Send reminder emails for pending approvals older than this many hours (0 to disable)
APPROVAL_PENDING_THRESHOLD_HOURS=24

# Secret key for generating secure approval tokens (change in production)
APPROVAL_SECRET=change-this-to-a-random-string-in-production

# Bypasses user authentication for testing purposes
TEST_MODE=false
